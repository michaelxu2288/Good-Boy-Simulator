# copy this file to .env and fill in from the Supabase dashboard:
#   Project Settings -> API keys
# use the PUBLISHABLE key (sb_publishable_...) or the legacy anon "public" JWT (eyJ...).
# NEVER put the secret key (sb_secret_...) here — it ships to the browser and bypasses RLS.
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_your_key_here
